{
  "info": {
    "name": "AlphaLinkup Backend API - ULTIMATE (100% Complete)",
    "description": "Complete collection of ALL endpoints (User & Admin).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://alphalinkup.com/api", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "user_id", "value": "MQ==", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        { "name": "Send OTP", "request": { "method": "POST", "url": "{{baseUrl}}/Api-Send-Otp", "body": { "mode": "formdata", "formdata": [{ "key": "mobile", "value": "" }] } } },
        { "name": "Verify OTP", "request": { "method": "POST", "url": "{{baseUrl}}/Api-Verify-Otp", "body": { "mode": "formdata", "formdata": [{ "key": "mobile", "value": "" }, { "key": "otp", "value": "" }] } } },
        { "name": "Login", "request": { "method": "POST", "url": "{{baseUrl}}/Api-Login", "body": { "mode": "formdata", "formdata": [{ "key": "mobile", "value": "" }, { "key": "password", "value": "" }] } } },
        { "name": "Logout", "request": { "method": "POST", "url": "{{baseUrl}}/Api-Logout", "body": { "mode": "formdata", "formdata": [{ "key": "user_id", "value": "{{user_id}}" }, { "key": "token", "value": "{{token}}" }] } } }
      ]
    },
    {
      "name": "2. Master Data",
      "item": [
        { "name": "Country List", "request": { "method": "GET", "url": "{{baseUrl}}/Api-Country-List" } },
        { "name": "State List", "request": { "method": "POST", "url": "{{baseUrl}}/Api-State-List", "body": { "mode": "formdata", "formdata": [{ "key": "country_id", "value": "1" }] } } },
        { "name": "City List", "request": { "method": "POST", "url": "{{baseUrl}}/Api-City-List", "body": { "mode": "formdata", "formdata": [{ "key": "state_id", "value": "" }] } } },
        { "name": "Interests List", "request": { "method": "GET", "url": "{{baseUrl}}/Api-Interests-List" } },
        { "name": "Employment Type List", "request": { "method": "GET", "url": "{{baseUrl}}/Api-Employment-Type-List" } },
        { "name": "Job Type List", "request": { "method": "GET", "url": "{{baseUrl}}/Api-Job-Type-List" } }
      ]
    },
    {
      "name": "3. Admin Panel (Full System)",
      "item": [
        { "name": "Admin Login", "request": { "method": "POST", "url": "{{baseUrl}}/admin-login", "body": { "mode": "formdata", "formdata": [{ "key": "username", "value": "superadmin" }, { "key": "password", "value": "superadmin" }] } } },
        { "name": "Admin Dashboard", "request": { "method": "POST", "url": "{{baseUrl}}/admin-dashboard", "body": { "mode": "formdata", "formdata": [{ "key": "user_id", "value": "{{user_id}}" }, { "key": "token", "value": "{{token}}" }] } } },
        { "name": "List Users (AJAX)", "request": { "method": "POST", "url": "{{baseUrl}}/list-users-ajax", "body": { "mode": "formdata", "formdata": [{ "key": "user_id", "value": "{{user_id}}" }, { "key": "token", "value": "{{token}}" }, { "key": "start", "value": "0" }, { "key": "length", "value": "10" }] } } },
        { "name": "Submit User", "request": { "method": "POST", "url": "{{baseUrl}}/submit-users", "body": { "mode": "formdata", "formdata": [{ "key": "user_id", "value": "{{user_id}}" }, { "key": "full_name", "value": "" }, { "key": "role_id", "value": "3" }] } } },
        { "name": "List Investors", "request": { "method": "POST", "url": "{{baseUrl}}/list-investors-ajax" } },
        { "name": "Submit Investor", "request": { "method": "POST", "url": "{{baseUrl}}/submit-investors", "body": { "mode": "formdata", "formdata": [{ "key": "name", "value": "" }] } } },
        { "name": "List Jobs", "request": { "method": "POST", "url": "{{baseUrl}}/list-jobs-ajax" } },
        { "name": "Submit Job", "request": { "method": "POST", "url": "{{baseUrl}}/submit-jobs", "body": { "mode": "formdata", "formdata": [{ "key": "job_title", "value": "" }] } } },
        { "name": "List Events", "request": { "method": "POST", "url": "{{baseUrl}}/list-events-ajax" } },
        { "name": "Submit Event", "request": { "method": "POST", "url": "{{baseUrl}}/submit-events", "body": { "mode": "formdata", "formdata": [{ "key": "event_name", "value": "" }] } } },
        { "name": "List Locations (Admin)", "item": [
          { "name": "List Country (Admin)", "request": { "method": "POST", "url": "{{baseUrl}}/list-country" } },
          { "name": "Save Country (Admin)", "request": { "method": "POST", "url": "{{baseUrl}}/save-country" } },
          { "name": "List States (Admin)", "request": { "method": "POST", "url": "{{baseUrl}}/list-state" } },
          { "name": "Submit State (Admin)", "request": { "method": "POST", "url": "{{baseUrl}}/submit-state" } },
          { "name": "List Cities (Admin)", "request": { "method": "POST", "url": "{{baseUrl}}/list-city" } }
        ]}
      ]
    },
    {
      "name": "4. User Operations",
      "item": [
        { "name": "View Profile", "request": { "method": "POST", "url": "{{baseUrl}}/Api-View-Profile", "body": { "mode": "formdata", "formdata": [{ "key": "user_id", "value": "{{user_id}}" }, { "key": "token", "value": "{{token}}" }] } } },
        { "name": "Update Profile", "request": { "method": "POST", "url": "{{baseUrl}}/Api-Update-Profile", "body": { "mode": "formdata", "formdata": [{ "key": "user_id", "value": "{{user_id}}" }] } } },
        { "name": "Chat History", "request": { "method": "POST", "url": "{{baseUrl}}/Api-View-Chat", "body": { "mode": "formdata", "formdata": [{ "key": "chat_user_id", "value": "" }] } } },
        { "name": "Apply for Job", "request": { "method": "POST", "url": "{{baseUrl}}/Api-Apply-Job", "body": { "mode": "formdata", "formdata": [{ "key": "job_id", "value": "" }, { "key": "resume_file", "type": "file" }] } } },
        { "name": "Save Event", "request": { "method": "POST", "url": "{{baseUrl}}/Api-Save-Event-Information", "body": { "mode": "formdata", "formdata": [{ "key": "event_name", "value": "" }] } } }
      ]
    },
    {
      "name": "5. Advanced Support",
      "item": [
        { "name": "Update FCM Token", "request": { "method": "POST", "url": "{{baseUrl}}/Api-Update-FCM-Token", "body": { "mode": "formdata", "formdata": [{ "key": "fcm_token", "value": "" }] } } },
        { "name": "Admin Permissions", "request": { "method": "POST", "url": "{{baseUrl}}/admin-permissions-list" } },
        { "name": "Sub-admin Management", "request": { "method": "POST", "url": "{{baseUrl}}/admin-subadmin-list" } }
      ]
    }
  ]
}