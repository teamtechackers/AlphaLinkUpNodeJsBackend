{
  "info": {
    "name": "AlphaLinkup Backend API",
    "description": "Comprehensive collection of all user and admin APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://alphalinkup.com/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "MQ==",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/Api-Send-Otp" },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "mobile", "value": "03001234567", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/Api-Verify-Otp" },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "mobile", "value": "03001234567", "type": "text" },
                { "key": "otp", "value": "1234", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/Api-Login" },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "mobile", "value": "", "type": "text" },
                { "key": "password", "value": "", "type": "text" },
                { "key": "fcm_token", "value": "", "type": "text" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2. Admin Panel",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/admin-login" },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "username", "value": "superadmin", "type": "text" },
                { "key": "password", "value": "superadmin", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Admin Dashboard",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/admin-dashboard" },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "user_id", "value": "{{user_id}}", "type": "text" },
                { "key": "token", "value": "{{token}}", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "User List (AJAX)",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/list-users-ajax" },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "user_id", "value": "{{user_id}}", "type": "text" },
                { "key": "token", "value": "{{token}}", "type": "text" },
                { "key": "draw", "value": "1", "type": "text" },
                { "key": "start", "value": "0", "type": "text" },
                { "key": "length", "value": "10", "type": "text" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3. Master Data",
      "item": [
        {
          "name": "Country List",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/Api-Country-List" }
          }
        },
        {
          "name": "State List",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/Api-State-List" },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "country_id", "value": "1", "type": "text" }
              ]
            }
          }
        }
      ]
    }
  ]
}